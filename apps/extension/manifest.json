{
  "manifest_version": 3,
  "name": "clickthru capture",
  "version": "0.3.0",
  "description": "Ekranını kaydet → tıklamalar adım, scroll'lar video → tıklanabilir demo.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "clickthru capture"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": ["tabs", "storage", "scripting", "tabCapture", "offscreen"],
  "host_permissions": ["<all_urls>"],
  "commands": {
    "stop-recording": {
      "suggested_key": { "default": "Ctrl+Shift+Y" },
      "description": "clickthru kaydını durdur"
    }
  }
}
