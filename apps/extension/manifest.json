{
  "manifest_version": 3,
  "name": "clickthru capture",
  "version": "0.2.0",
  "description": "Tıklamaları yakala → ekran görüntüsü + hotspot → tıklanabilir demo.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "clickthru capture"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": ["tabs", "storage", "scripting"],
  "host_permissions": ["<all_urls>"]
}
